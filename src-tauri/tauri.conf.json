{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "super-kafka",
  "version": "0.1.1",
  "identifier": "com.jacksonary.super-kafka",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Super Kafka",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": [
          "English",
          "SimpChinese"
        ],
        "displayLanguageSelector": true,
        "installMode": "both",
        "template": "nsis/installer.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMTIwQkJDNjI3MkZBOEQKUldTTituSml2QXNTc1hjWW1kSHBzQTBSSGVaZk1CWThYeGd3QlVuT3FaVnlFQnlCTHZXL29JU1cK",
      "endpoints": [
        "https://github.com/Jacksonary/super-kafka/releases/latest/download/latest.json"
      ]
    }
  }
}
